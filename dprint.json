{
    "typescript": {
        "lineWidth": 100,
        "indentWidth": 4,
        "quoteStyle": "preferDouble",
        "semiColons": "always",
        "preferSingleLine": false,
        "useBraces": "preferNone",
        "ifStatement.singleBodyPosition": "nextLine"
    },
    "json": {
        "indentWidth": 4
    },
    "excludes": [
        "**/node_modules",
        "**/dist"
    ],
    "plugins": [
        "https://plugins.dprint.dev/typescript-0.95.15.wasm",
        "https://plugins.dprint.dev/json-0.21.1.wasm"
    ]
}
